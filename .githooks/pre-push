#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

run_check() {
	local name="$1"
	shift
	echo "pre-push: running $name..."
	"$@"
}

run_race_tests() {
	local skip_monty
	skip_monty="$(git config --bool --get hooks.skipMontyRace || true)"

	local -a packages=()
	while IFS= read -r pkg; do
		if [[ -z "$pkg" ]]; then
			continue
		fi
		if [[ "$skip_monty" == "true" && "$pkg" == "github.com/fugue-labs/gollem/ext/monty" ]]; then
			continue
		fi
		packages+=("$pkg")
	done < <(go list ./...)

	if [[ "$skip_monty" == "true" ]]; then
		echo "pre-push: skipping race tests for github.com/fugue-labs/gollem/ext/monty (hooks.skipMontyRace=true)"
	fi

	go test -race "${packages[@]}"
}

run_check "golangci-lint" golangci-lint run ./...
run_check "go test -race" run_race_tests
run_check "go vet" go vet ./...

echo "pre-push: verifying go.mod/go.sum are tidy..."
go mod tidy
git diff --exit-code go.mod go.sum >/dev/null || {
	echo "pre-push: go.mod/go.sum changed after 'go mod tidy'."
	echo "Run 'go mod tidy', commit the updates, then push again."
	exit 1
}

echo "pre-push: all checks passed."
