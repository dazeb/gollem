#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

run_check() {
	local name="$1"
	shift
	echo "pre-push: running $name..."
	"$@"
}

run_check "golangci-lint" golangci-lint run ./...
run_check "go test -race" go test -race ./...
run_check "go vet" go vet ./...

echo "pre-push: verifying go.mod/go.sum are tidy..."
go mod tidy
git diff --exit-code go.mod go.sum >/dev/null || {
	echo "pre-push: go.mod/go.sum changed after 'go mod tidy'."
	echo "Run 'go mod tidy', commit the updates, then push again."
	exit 1
}

echo "pre-push: all checks passed."

