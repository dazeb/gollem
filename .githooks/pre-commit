#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_go_files=()
while IFS= read -r file; do
	if [[ -n "$file" && "$file" == *.go ]]; then
		staged_go_files+=("$file")
	fi
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ ${#staged_go_files[@]} -eq 0 ]]; then
	exit 0
fi

unformatted="$(gofmt -l "${staged_go_files[@]}")"
if [[ -n "$unformatted" ]]; then
	echo "pre-commit: gofmt check failed for staged Go files:"
	echo "$unformatted"
	echo "Run: gofmt -w <files> (or make fmt) and re-stage."
	exit 1
fi

